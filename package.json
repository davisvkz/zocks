{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "monolith_hexagonal_layered_ddd",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.3.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "format": "turbo format --continue --concurrency 12 -- --cache --cache-location node_modules/.cache/.prettiercache",
    "format:fix": "turbo format --continue --concurrency 12 -- --write --cache --cache-location node_modules/.cache/.prettiercache",
    "lint": "turbo lint --continue -- --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "turbo lint --continue -- --fix --cache-location node_modules/.cache/.eslint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --parallel",
    "prepare": "husky && husky install"
  },
  "devDependencies": {
    "gitmoji-cli": "^9.7.0",
    "husky": "^8.0.0",
    "turbo": "^2.6.1"
  }
}
