{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../tooling/typescript-config/node.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["shared/*"],
			"@modules/shared/*": ["shared/*"],
			"@modules/users/*": ["modules/users/*"]
		},
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"include": ["."]
}
